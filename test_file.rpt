set f [open "ocv_timing.rpt" w]
puts $f "# path_name  nominal_slack  derate_factor  ocv_slack"
puts $f "PATH_CORE_0   0.352   0.97   0.241"
puts $f "PATH_CORE_1  -0.128   0.97  -0.283"
puts $f "PATH_IO_0    -0.890   0.95  -1.021"
puts $f "PATH_IO_1     0.073   0.95  -0.031"
puts $f "PATH_IO_2     0.180   0.95   0.062"
puts $f "PATH_MEM_0    0.445   0.98   0.381"
puts $f "PATH_MEM_1   -0.052   0.98  -0.103"
close $f

set f [open "design.sdc" w]
puts $f "create_clock -name CLK_CORE -period 10.0 -waveform {0 5} \[get_ports clk\]"
puts $f "create_clock -name CLK_IO   -period 25.0 \[get_ports io_clk\]"
puts $f "set_input_delay  -clock CLK_CORE -max 2.0 \[get_ports {data_in*}\]"
puts $f "set_input_delay  -clock CLK_CORE -min 0.5 \[get_ports {data_in*}\]"
puts $f "set_output_delay -clock CLK_CORE -max 1.5 \[get_ports {data_out*}\]"
puts $f "set_false_path -from \[get_clocks CLK_CORE\] -to \[get_clocks CLK_IO\]"
puts $f "set_multicycle_path -setup 2 -from \[get_cells slow_reg*\]"
puts $f "set_multicycle_path -hold  1 -from \[get_cells slow_reg*\]"
close $f

set f [open "clock_timing.rpt" w]
puts $f "# Format: FF_name  clock_domain  arrival_ps"
puts $f "FF_REG_0   CLK_CORE   1250"
puts $f "FF_REG_1   CLK_CORE   1380"
puts $f "FF_REG_2   CLK_CORE   1190"
puts $f "FF_REG_3   CLK_CORE   1420"
puts $f "FF_REG_4   CLK_IO     2100"
puts $f "FF_REG_5   CLK_IO     2350"
puts $f "FF_REG_6   CLK_IO     1980"
close $f
